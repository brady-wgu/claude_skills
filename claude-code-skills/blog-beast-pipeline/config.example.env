# ============================================================
# blog-beast-pipeline configuration
# Copy this file to .env and fill in your values.
# ============================================================

# Coda API key (generate at https://coda.io/account under "API settings")
CODA_API_KEY=your-coda-api-key-here

# Coda document ID (found in your doc URL: coda.io/d/Your-Doc_d<DOC-ID>)
CODA_DOC_ID=your-coda-doc-id-here

# Absolute path to the pipeline directory (used by the Claude Code skill plugin)
# Example: C:/Users/you/Projects/blog-beast-pipeline
# PIPELINE_DIR=
